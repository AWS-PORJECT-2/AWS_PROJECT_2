# ===== 운영 필수 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
# 실제 RDS 호스트는 팀 내부 채널(슬랙 등)로 공유. 예시 placeholder:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@<RDS_HOST>.<REGION>.rds.amazonaws.com:5432/postgres

# RDS SSL 검증용 CA 번들 경로 (권장).
# 다운로드: https://truststore.pki.rds.amazonaws.com/<region>/<region>-bundle.pem
# 프로젝트에 포함된 인증서: certs/rds-global-bundle.pem (전 리전 번들) 또는 certs/rds-ca-us-east-1.pem
# 미지정 시 production 에서는 부팅 차단(fail-closed).
DATABASE_SSL_CA=./certs/rds-global-bundle.pem
# 로컬 개발에서 SSL 미사용 Postgres 를 쓸 경우 'disabled' 로 설정.
DATABASE_SSL=

# ===== 일반 설정 =====
PORT=3000
FRONTEND_URL=http://localhost:3000
# ⚠️ 운영 배포는 반드시 production. development 면 dev-auth 백도어 노출·secure 쿠키 비활성 등 보안 가드가 일괄 해제된다.
#    로컬 개발만 development 로 바꿔 쓸 것.
NODE_ENV=production

# ===== AI (OpenAI) =====
# 키 미설정 시 이미지 라우트(/api/ai/*)가 아예 등록되지 않음 (404). 실수로 빈 키로 호출되는 사고 차단.
# OpenAI 플랫폼에서 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- 이미지 생성/가상피팅 (gpt-image-1) ---
# 모델 ID (기본: gpt-image-1).
OPENAI_IMAGE_MODEL=gpt-image-1
# 생성 품질: low | medium | high | auto (비용↔품질, 기본 medium).
OPENAI_IMAGE_QUALITY=medium
# 이미지 일일 호출 한도 (기본 30). 한도 초과 시 503. 자정 UTC 리셋.
AI_IMAGE_DAILY_LIMIT=30
# OpenAI 이미지 클라이언트 호출 timeout (ms, 기본 120000).
OPENAI_IMAGE_TIMEOUT_MS=120000

# --- 스토리 초안 생성 (gpt-4o-mini) ---
# 모델 ID (기본: gpt-4o-mini).
OPENAI_TEXT_MODEL=gpt-4o-mini
# 텍스트 일일 호출 한도 (기본 50). 한도 초과 시 503. 자정 UTC 리셋.
AI_TEXT_DAILY_LIMIT=50
# OpenAI 텍스트 클라이언트 호출 timeout (ms, 기본 60000).
OPENAI_TEXT_TIMEOUT_MS=60000

# --- 공통 ---
# 라우트 레벨 타임아웃 래퍼 (ms, 기본 60000). OPENAI_*_TIMEOUT_MS 는 OpenAI 클라이언트 자체 타임아웃이고,
# AI_TIMEOUT_MS 는 그 위에서 /api/ai/* 핸들러 응답 전체를 감싸는 상한이다. 권장: 60000~120000.
AI_TIMEOUT_MS=60000

# ===== 결제 시스템 (토스페이먼츠 V2 직접 연동) =====
# production 에서는 반드시 설정 필요. dev 에서는 미설정 시 더미 키로 fallback.
# 토스페이먼츠 개발자센터 > API 키 메뉴에서 확인
TOSS_SECRET_KEY=test_sk_000000000000000000000000000
TOSS_CLIENT_KEY=test_ck_000000000000000000000000000
TOSS_WEBHOOK_SECRET=

# ===== 빌링키 암호화 (AES-256-GCM) =====
# 32바이트 hex 문자열 (64자). 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_ENCRYPTION_KEY=

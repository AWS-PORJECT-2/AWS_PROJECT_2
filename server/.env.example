# =====================================================================
# .env.example  — 실제 비밀번호/자격증명을 절대 적지 말 것.
# 로컬 개발자는 이 파일을 .env 로 복사한 뒤 자기 값으로 채우기.
# =====================================================================

# ===== Auth / OAuth =====
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
ACCESS_TOKEN_SECRET=REPLACE_ME_WITH_32_CHAR_RANDOM_HEX
REFRESH_TOKEN_SECRET=REPLACE_ME_WITH_32_CHAR_RANDOM_HEX

# ===== AWS RDS MySQL =====
DB_HOST=your-db-host.rds.amazonaws.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password_here
DB_PORT=3306
DB_NAME=doothing
# RDS SSL 인증서 (root에 다운로드)
DB_SSL_CA=../global-bundle.pem

# ===== 일반 설정 =====
PORT=3000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ===== AI 어댑터 (옵션) =====
# 미설정 시 NullAi* 어댑터로 fallback → /api/ai/* 가 503 응답.
AI_DESIGN_URL=
AI_COMFYUI_WORKFLOW_DIR=
AI_TRYON_URL=
AI_TRYON_MODEL_DIR=
AI_TIMEOUT_MS=60000

# ===== 무통장 입금 결제 시스템 =====
UPLOAD_DIR=./uploads/payments
MAX_FILE_SIZE=5242880

# ===== Mock OAuth (개발용) =====
USE_MOCK_OAUTH=true
MOCK_LOGIN_EMAIL=test@kookmin.ac.kr

# ===== 이메일 (Nodemailer) =====
# 개발 중에는 MAIL_DRY_RUN=true 권장 (실제 발송 없이 로그만)
MAIL_DRY_RUN=true
# Gmail 사용 예시:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
# AWS SES SMTP 사용 예시:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=두띵(Doothing) <noreply@kookmin.ac.kr>

# ===== 운영 필수 =====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@kmuproj-team2-rds.cj24wem202yj.us-east-1.rds.amazonaws.com:5432/postgres

# ===== 일반 설정 =====
PORT=3000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ===== 로컬 개발용 (운영에서는 false 또는 미설정) =====
# In-Memory 저장소 사용 — PostgreSQL 없이도 인증 흐름 테스트 가능. 재시작 시 데이터 휘발.
USE_INMEMORY=false

# Google OAuth 우회 (가짜 로그인). NODE_ENV=production 에서는 자동 무시됩니다.
USE_MOCK_OAUTH=false
MOCK_LOGIN_EMAIL=test@kookmin.ac.kr
